# Server Configuration
PORT=5000
NODE_ENV=development

# Session Security
# Generate a strong random string for production (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=a_very_long_random_string_for_session_security_12345

# Set to 'true' ONLY if you're using HTTPS (required for production)
# Leave as 'false' or comment out for local development (HTTP)
HTTPS_ENABLED=false

# Database
# SQLITE_DB_PATH=./backend/database.db
