{
  "name": "bunubon-gui-controller",
  "version": "1.0.0",
  "description": "Windows GUI Controller for Bunubon Land Title Tracking System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:frontend && npm run build:backend && electron-builder --win --x64",
    "build:portable": "npm run build:frontend && npm run build:backend && electron-builder --win portable --x64",
    "build:all": "npm run build && npm run build:portable",
    "build:frontend": "cd ../frontend && npm install && npm run build",
    "build:backend": "cd ../backend && npm install --production"
  },
  "keywords": [
    "land-titles",
    "gui",
    "controller",
    "electron"
  ],
  "author": "Department of Agrarian Reform - La Union",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.dar.bunubon.controller",
    "productName": "Bunubon LTS Controller",
    "artifactName": "Bunubon-LTS-Controller-${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/node_modules",
          "!**/*.test.js",
          "!**/tests/**",
          "!.env",
          "!logs/**"
        ]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "requestedExecutionLevel": "asInvoker",
      "sign": null,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Bunubon-LTS-Controller-Portable-${version}.exe",
      "unpackDirName": "Bunubon-Portable"
    }
  }
}